# ---------- Database (NeonDB) ----------
# Pooled connection string (host contains "-pooler"). Used by the app at runtime.
DATABASE_URL="postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"
# Direct connection string (no "-pooler"). Used by `prisma migrate`.
DIRECT_URL="postgresql://<user>:<password>@<endpoint>.<region>.aws.neon.tech/<db>?sslmode=require"

# ---------- Auth (NextAuth) ----------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-strong-random-32-byte-value"
# Production: set to your deployed URL, e.g. https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# Seed admin (prisma/seed.ts creates the first admin). Use a STRONG password in prod.
SEED_ADMIN_EMAIL="admin@portal.local"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"
SEED_ADMIN_NAME="Portal Admin"

# ---------- Token encryption ----------
# 32-byte random. Encrypts stored Gmail tokens + Groq key (AES-256-GCM).
# WARNING: changing this invalidates already-connected Gmail + saved Groq keys.
APP_ENC_KEY="replace-with-a-strong-random-32-byte-value"

# ---------- Gmail integration (Google Cloud OAuth, Gmail API enabled) ----------
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="..."
# Production: https://your-app.vercel.app/api/google/callback (also add it in Google Cloud)
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"

# ---------- AI bid generation (optional global fallback; per-user key set in Settings) ----------
GROQ_API_KEY=""

# ---------- Attachments storage (production / Vercel) ----------
# From Vercel → Storage → Blob. If unset, attachments fall back to local disk (./storage) for dev.
BLOB_READ_WRITE_TOKEN=""

# ---------- Scheduler (Vercel Cron) ----------
# Protects /api/cron/ingest. Set the same value in Vercel project env + it's sent by Vercel Cron.
CRON_SECRET=""
